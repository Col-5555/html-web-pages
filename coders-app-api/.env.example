# Copy this file to .env and fill in the values. .env is gitignored — never
# commit real credentials.

# Port the Express API listens on. 4000 is a safe default on this shared machine
# (3000 and 8080 are held by other users; the managers app uses 8457/3457).
PORT=4000

# MongoDB Atlas connection. Get the SRV URI from your Atlas cluster
# ("Connect" → "Drivers"). The DB name is the database Mongoose will use.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB=ImpDatabaseDesign
