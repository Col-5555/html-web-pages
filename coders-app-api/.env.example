# Reference for every configuration variable the API reads. The app no longer
# loads a single .env — instead config/env.js picks a per-environment file based
# on APP_ENV (set by cross-env in the npm scripts):
#
#   APP_ENV=dev   -> .env.dev    (npm run dev)   -- see .env.dev.example
#   APP_ENV=test  -> .env.test   (npm test)      -- see .env.test.example
#   APP_ENV=prod  -> .env.prod   (npm start)
#
# Copy the matching .env.<env>.example to .env.<env> and fill in the values.
# All .env.<env> files are gitignored — never commit real credentials. Test and
# dev share one Atlas cluster but use different MONGODB_DB databases.

# Port the Express API listens on. 4000 is a safe default on this shared machine
# (3000 and 8080 are held by other users; the managers app uses 8457/3457).
PORT=4000

# MongoDB Atlas connection. Get the SRV URI from your Atlas cluster
# ("Connect" → "Drivers"). The DB name is the database Mongoose will use.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB=ImpDatabaseDesign

# Secret used to sign/verify JWTs (email-verification + login tokens). Use a
# long random string in real deployments.
JWT_SECRET=change-me-to-a-long-random-secret

# Public base URL the email-verification link is built from. The registration
# email points to ${APP_URL}/api/auth/verify?token=<jwt>.
APP_URL=http://localhost:4000

# SMTP for sending the verification email. Leave these unset in development to
# use a throwaway Ethereal test account (the server logs a preview URL instead
# of really delivering mail).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-pass

# External code runner used to grade submissions. Defaults to the runner provided
# with the brief; override the URL or the (generous, for cold starts) timeout here.
# CODE_RUNNER_URL=https://runlang-v1.onrender.com/run
# CODE_RUNNER_TIMEOUT_MS=60000
