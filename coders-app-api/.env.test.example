# Test environment. Copy this file to .env.test and fill in the values. Loaded by
# config/env.js when the app runs with APP_ENV=test (the `npm test` script and
# the Supertest suite). See .env.example for what each variable means.
#
# .env.test is gitignored — never commit real credentials.
#
# Uses the SAME Atlas cluster as dev but a SEPARATE database (MONGODB_DB), so the
# test suite can seed and wipe data without touching development/production data.

PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
# A dedicated test database — the suite drops its collections after each run.
MONGODB_DB=ImpDatabaseDesign_test
JWT_SECRET=change-me-to-a-long-random-secret
APP_URL=http://localhost:4000
# Supabase Storage (only needed if a test actually exercises avatar upload).
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=your-supabase-service-key
SUPABASE_BUCKET=avatars
