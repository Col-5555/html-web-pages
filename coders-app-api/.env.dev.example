# Development environment. Copy this file to .env.dev and fill in the values.
# Loaded by config/env.js when the app runs with APP_ENV=dev (the `npm run dev`
# script). See .env.example for what each variable means.
#
# .env.dev is gitignored — never commit real credentials.

PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
# Dev uses the main working database.
MONGODB_DB=ImpDatabaseDesign
JWT_SECRET=change-me-to-a-long-random-secret
APP_URL=http://localhost:4000
# Supabase Storage for avatar uploads (see .env.example). Use a server-side key.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=your-supabase-service-key
SUPABASE_BUCKET=avatars
