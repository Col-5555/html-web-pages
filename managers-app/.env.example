# Copy to `.env` to override. The managers dashboard talks to two real backends
# (server-side): the Express API for auth, and the NestJS API for challenges.
# Both default to these values if unset.

# Express backend (coders-app-api) — manager registration + login.
EXPRESS_API_URL=http://localhost:4000

# NestJS backend (managers-app-api) — challenges CRUD.
NESTJS_API_URL=http://localhost:4100
