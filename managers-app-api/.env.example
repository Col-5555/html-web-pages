# Copy this file to .env and fill in the values. .env is gitignored — never
# commit real credentials.

# Port this NestJS app listens on. 4100 keeps clear of the other apps on this
# machine (Express API 4000; managers-app 8457/3457; 3000/8080 are taken).
PORT=4100

# MongoDB Atlas connection — the SAME database the Express coders-app-api uses, so
# both backends read/write one set of challenges/users.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB=ImpDatabaseDesign

# JWT secret used to VERIFY manager tokens. It must match the coders-app-api
# JWT_SECRET, because managers log in through the Express backend and pass that
# token here in the Authorization header.
JWT_SECRET=must-match-the-express-backend-secret
