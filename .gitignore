# Monorepo root ignore — applies to both coders-app/ and managers-app/.
# (Patterns without a leading slash match at any depth.)

# Dependencies
node_modules

# Build output / caches
dist
dist-ssr
build
.next
out
.vite

# Logs
logs
*.log
npm-debug.log*

# Env / local
*.local
.env
.env*.local
# Per-environment files (.env.test / .env.dev / .env.prod) hold real credentials —
# ignore them all, but keep the committed *.example templates.
.env.*
!.env.example
!.env.*.example

# Editor / OS
.vscode/*
!.vscode/extensions.json
.DS_Store
